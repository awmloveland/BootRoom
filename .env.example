# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For data migration only (run scripts/migrate-data.mjs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: lock production (m.craft-football.com) behind secret URL key
# Only enforced on production; localhost works without a key
APP_ACCESS_KEY=your-secret-key

# When using APP_ACCESS_KEY in production, set this so the app fetches from API routes
NEXT_PUBLIC_ACCESS_KEY_MODE=true
