# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use ANON_KEY or PUBLISHABLE_KEY (Supabase Vercel integration may set the latter)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Hosted Supabase: add redirect URLs in Dashboard → Authentication → URL Configuration
# See SUPABASE_SETUP.md for the full list

# For data migration only (run scripts/migrate-data.mjs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: lock production behind a secret URL key
# Only enforced on production; localhost works without a key
APP_ACCESS_KEY=your-secret-key

# When using APP_ACCESS_KEY in production, set this so the app fetches from API routes
NEXT_PUBLIC_ACCESS_KEY_MODE=true
